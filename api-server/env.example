# 复制为 .env 并填入真实值

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pianoai:password@db:5432/pianoai

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate one by openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Apple Sign In + IAP ───────────────────────────────────────────────────────
# com.yourcompany.pianolearn and your-apple-shared-secret
APPLE_APP_BUNDLE_ID=
APPLE_SHARED_SECRET=
APPLE_VERIFY_URL=https://buy.itunes.apple.com/verifyReceipt
APPLE_SANDBOX_VERIFY_URL=https://sandbox.itunes.apple.com/verifyReceipt

# ── Google Sign In ────────────────────────────────────────────────────────────
# your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# ── S3 / Cloudflare R2 ────────────────────────────────────────────────────────
# R2 示例：endpoint_url = https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=auto

# ── Twilio（手机 OTP）────────────────────────────────────────────────────────
# 留空则开发模式下 OTP 打印到终端日志
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── 应用 ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development    # development | production
DEBUG=false
