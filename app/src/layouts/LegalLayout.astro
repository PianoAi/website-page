---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  updated: string;
}

const { title, description, updated } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | PianoAi</title>
    <meta name="description" content={description} />
  </head>
  <body class="font-sans">
    <Header />
    <main class="bg-background px-6 pt-36 pb-24 sm:px-10">
      <div class="mx-auto max-w-180">
        <h1
          class="text-[clamp(2rem,5vw,3rem)] font-extrabold leading-tight tracking-tight bg-linear-to-br from-white via-[#a78bfa] to-accent-cyan bg-clip-text text-transparent"
        >
          {title}
        </h1>
        <p class="mt-3 text-sm text-secondary">Last updated: {updated}</p>

        <div class="legal-content mt-12">
          <slot />
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .legal-content :global(h2) {
    margin-top: 2.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.01em;
  }

  .legal-content :global(p) {
    margin-top: 1rem;
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-secondary);
  }

  .legal-content :global(ul) {
    margin-top: 1rem;
    list-style-type: disc;
    padding-left: 1.5rem;
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-secondary);
  }

  .legal-content :global(li) {
    margin-top: 0.5rem;
  }

  .legal-content :global(a) {
    color: var(--color-accent-cyan);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-content :global(strong) {
    color: var(--color-foreground);
  }
</style>
