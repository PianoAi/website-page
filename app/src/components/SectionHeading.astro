---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mx-auto max-w-160 text-center">
  <div
    class="inline-block rounded-full border border-accent-cyan/40 bg-accent-cyan/5 px-4 py-1.5 text-[11px] font-semibold uppercase tracking-[0.2em] text-accent-cyan backdrop-blur-md"
  >
    {eyebrow}
  </div>
  <h2
    class="mt-5 text-[clamp(1.75rem,5vw,2.75rem)] font-extrabold leading-tight tracking-tight bg-linear-to-br from-white via-[#a78bfa] to-accent-cyan bg-clip-text text-transparent"
  >
    {title}
  </h2>
  {description && <p class="mt-4 text-base leading-relaxed text-secondary">{description}</p>}
</div>
