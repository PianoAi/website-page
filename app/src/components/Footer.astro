---
const links = [
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
  { label: "Support", href: "/support" },
];
---

<footer class="border-t border-white/10 px-6 py-10 sm:px-10">
  <div class="mx-auto flex max-w-300 flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
    <div>
      <div class="flex items-center justify-center gap-2 text-lg font-extrabold tracking-tight text-white sm:justify-start">
        <img src="/logo.png" alt="PianoAi" class="h-7 w-7" />
        Piano<span class="bg-linear-to-br from-[#a78bfa] to-accent-cyan bg-clip-text text-transparent">Ai</span>
      </div>
      <p class="mt-1 text-sm text-secondary">AI-powered piano education, from first note to full song.</p>
    </div>

    <nav class="flex flex-wrap items-center justify-center gap-6">
      {links.map((link) => (
        <a href={link.href} class="text-sm text-secondary transition-colors hover:text-white">
          {link.label}
        </a>
      ))}
    </nav>
  </div>

  <p class="mt-8 text-center text-xs text-secondary/60">
    &copy; {new Date().getFullYear()} PianoAi. All rights reserved.
  </p>
</footer>
