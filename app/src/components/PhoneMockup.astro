---
interface Props {
  label: string;
  accent?: string;
  src?: string;
  showLabel?: boolean;
}

const { label, accent = "from-primary/30 to-accent-cyan/15", src, showLabel = true } = Astro.props;
---

<div class="relative w-full max-w-65 mx-auto">
  <div class="aspect-9/19.5 rounded-[2.5rem] border border-white/10 bg-white/5 backdrop-blur-md p-3 shadow-2xl shadow-primary/10">
    {src ? (
      <div class="relative h-full w-full overflow-hidden rounded-[1.8rem] bg-background">
        <img src={src} alt={label} class="h-full w-full object-cover object-top" />
        <!-- notch -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 h-5 w-20 rounded-b-xl bg-background/80"></div>
      </div>
    ) : (
      <div class={`relative h-full w-full overflow-hidden rounded-[1.8rem] bg-linear-to-br ${accent} flex flex-col gap-3 p-4`}>
        <!-- notch -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 h-5 w-20 rounded-b-xl bg-background/80"></div>
        <!-- skeleton content -->
        <div class="mt-8 h-3 w-2/3 rounded-full bg-white/20"></div>
        <div class="h-24 w-full rounded-2xl bg-white/10"></div>
        <div class="h-3 w-1/2 rounded-full bg-white/15"></div>
        <div class="mt-2 grid grid-cols-2 gap-2">
          <div class="h-16 rounded-xl bg-white/10"></div>
          <div class="h-16 rounded-xl bg-white/10"></div>
        </div>
        <div class="h-3 w-1/3 rounded-full bg-white/15"></div>
        <div class="h-10 w-full rounded-xl bg-white/10"></div>
      </div>
    )}
  </div>
  {showLabel && (
    <div class="mt-4 text-center text-[10px] font-medium uppercase tracking-[0.2em] text-secondary">
      {label}
    </div>
  )}
</div>
